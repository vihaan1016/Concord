PORT=3001
RPC_URL=https://sepolia.rpc.zama.ai
CHAIN_ID=11155111
DEX_ADDRESS=0x...
# Backfill starts here. Set it a few hundred blocks before "now" (Sepolia ~12s/block, so
# ~300 blocks ≈ 1h ≈ several batches). NOT 0 — 0 falls back to head-100. Going too far back
# just makes backfill slower; the live watcher + current-batch snapshot cover everything after.
START_BLOCK=0
# Blocks per eth_getLogs backfill chunk. IMPORTANT: Alchemy's FREE tier caps eth_getLogs at a
# 10-block range — larger values make the whole backfill fail. Keep this at 10 on Alchemy free;
# only raise it on a paid/unmetered RPC.
BACKFILL_BLOCK_RANGE=10
DATABASE_URL=postgresql://keeper:keeper@localhost:15432/fba_keeper
# Must include every frontend origin that calls this API (dev + the deployed Railway/Vercel URL).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4173,http://localhost:4174,http://localhost:4175,https://concord-production-34a5.up.railway.app
LOG_LEVEL=info
