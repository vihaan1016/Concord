# Private Key for Deployment and Testing
# WARNING: Never commit your actual private key! Use a test account for Sepolia.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Sepolia RPC URL
# Get a free RPC URL from:
# - Infura: https://infura.io/
# - Alchemy: https://alchemy.com/
# - Zama Sepolia RPC: https://sepolia.rpc.zama.ai
RPC_URL=https://sepolia.rpc.zama.ai

# Etherscan API Key (for contract verification)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# Deployed Contract Addresses (fill in after deployment)
DEX_ADDRESS=
BASE_TOKEN_ADDRESS=
QUOTE_TOKEN_ADDRESS=

# Keeper Configuration
KEEPER_ADDRESS=
KEEPER_PRIVATE_KEY=

# Frontend Configuration
NEXT_PUBLIC_DEX_ADDRESS=
NEXT_PUBLIC_BASE_TOKEN_ADDRESS=
NEXT_PUBLIC_QUOTE_TOKEN_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_URL=https://sepolia.rpc.zama.ai

# Database Configuration (for Keeper)
DATABASE_URL=postgresql://user:password@localhost:5432/fba_keeper

# Monitoring (optional)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
